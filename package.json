{
  "name": "material-factory-v4",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "rm -rf dist && tsc",
    "check:puppeteer": "node check-puppeteer.js",
    "start": "yarn check:puppeteer && node dist/index.js",
    "start:pm2": "yarn check:puppeteer && pm2 start ecosystem.config.js"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "puppeteer": "19.7.5",
    "puppeteer-cluster": "^0.23.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.13",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.8.0+sha512.0e82714d1b5b43c74610193cb20734897c1d00de89d0e18420aebc5977fa13d780a9cb05734624e81ebd81cc876cd464794850641c48b9544326b5622ca29971"
